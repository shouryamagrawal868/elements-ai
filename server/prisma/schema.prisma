generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  photoUrl  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  uploads   Upload[]

  @@map("users")
}

model Upload {
  id                   String       @id @default(uuid())
  userId               String
  fileName             String
  fileSize             Int
  fileType             String
  storagePath          String
  publicUrl            String?
  audioPath            String?
  thumbnailPath        String?
  status               UploadStatus @default(UPLOADED)
  processingStartedAt  DateTime?
  processingEndedAt    DateTime?
  thumbnailGeneratedAt DateTime?
  createdAt            DateTime     @default(now())
  updatedAt            DateTime     @updatedAt
  fingerprint          Fingerprint?
  user                 User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("uploads")
}

model Fingerprint {
  id          String   @id @default(uuid())
  uploadId    String   @unique
  duration    Int
  fingerprint String
  algorithm   String   @default("Chromaprint")
  version     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  upload      Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([algorithm])
  @@map("fingerprints")
}

enum UploadStatus {
  UPLOADED
  EXTRACTING_AUDIO
  GENERATING_THUMBNAIL
  GENERATING_FINGERPRINT
  COMPLETED
  FAILED
}
