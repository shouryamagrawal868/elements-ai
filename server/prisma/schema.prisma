generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  photoUrl String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploads Upload[]

  @@map("users")
}

model Upload {
  id String @id @default(uuid())

  userId String

  // Original uploaded video
  fileName String
  fileSize Int
  fileType String

  // Storage
  storagePath   String  @db.Text
  audioPath     String? @db.Text
  thumbnailPath String? @db.Text
  publicUrl     String? @db.Text

  // Processing
  status UploadStatus @default(UPLOADED)

  processingStartedAt DateTime?
  processingEndedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  recognitionResult RecognitionResult?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("uploads")
}

model RecognitionResult {
  id String @id @default(uuid())

  uploadId String @unique

  trackTitle String?
  artist     String?
  album      String?
  genre      String?

  duration    Int?
  bpm         Int?
  mood        String?
  releaseYear Int?

  spotifyUrl String? @db.Text
  youtubeUrl String? @db.Text
  coverUrl   String? @db.Text

  confidence Float?

  engine        RecognitionEngine?
  engineVersion String?

  processingTime Int?

  rawResponse Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  feedback Feedback?

  mlTrainingData MLTrainingData?

  @@index([trackTitle])
  @@index([artist])
  @@index([confidence])
  @@map("recognition_results")
}

model Feedback {
  id String @id @default(uuid())

  recognitionResultId String @unique

  isCorrect Boolean

  correctTrackTitle String?
  correctArtist     String?

  comment String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recognitionResult RecognitionResult @relation(fields: [recognitionResultId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

model MLTrainingData {
  id String @id @default(uuid())

  recognitionResultId String @unique

  predictedTrack  String?
  predictedArtist String?

  confidence Float?

  correctTrack  String?
  correctArtist String?

  verified Boolean @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  recognitionResult RecognitionResult @relation(fields: [recognitionResultId], references: [id], onDelete: Cascade)

  @@index([verified])
  @@map("ml_training_data")
}

enum UploadStatus {
  UPLOADED
  EXTRACTING_AUDIO
  RECOGNIZING
  COMPLETED
  FAILED
}

enum RecognitionEngine {
  ACOUSTID
  AUDD
  MUSICBRAINZ
  CUSTOM_AI
}
