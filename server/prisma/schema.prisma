generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id       String  @id @default(uuid())
  email    String  @unique
  name     String?
  photoUrl String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploads Upload[]

  @@map("users")
}

model Upload {
  id String @id @default(uuid())

  userId String

  fileName String
  fileSize Int
  fileType String

  storagePath   String
  publicUrl     String?
  audioPath     String?
  thumbnailPath String?

  status UploadStatus @default(UPLOADED)

  processingStartedAt  DateTime?
  processingEndedAt    DateTime?
  thumbnailGeneratedAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  fingerprint Fingerprint?

  audioFeature AudioFeature?

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("uploads")
}

model Song {
  id String @id @default(uuid())

  title String

  duration Int?

  language String?

  releaseYear Int?

  source String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  fingerprints Fingerprint[]

  @@index([title])
  @@map("songs")
}

model Fingerprint {
  id String @id @default(uuid())

  uploadId String @unique

  songId String?

  duration Int

  fingerprint String

  algorithm String @default("Chromaprint")

  version String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  song Song? @relation(fields: [songId], references: [id])

  @@index([songId])
  @@index([algorithm])
  @@map("fingerprints")
}

model AudioFeature {
  id String @id @default(uuid())

  uploadId String @unique

  duration Float

  sampleRate Int

  channels Int

  bitrate Int

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  upload Upload @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@map("audio_features")
}

enum UploadStatus {
  UPLOADED
  EXTRACTING_AUDIO
  GENERATING_THUMBNAIL
  GENERATING_FINGERPRINT
  COMPLETED
  FAILED
}
