generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  photoUrl  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  uploads   Upload[]

  @@map("users")
}

model Upload {
  id        String       @id @default(uuid())
  userId    String
  user      User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  fileName  String
  fileSize  Int
  fileType  String
  s3Key     String       @db.Text
  s3Url     String?      @db.Text
  status    UploadStatus @default(PROCESSING)
  createdAt DateTime     @default(now())
  updatedAt DateTime     @updatedAt
  result    RecognitionResult?

  @@index([userId])
  @@map("uploads")
}

enum UploadStatus {
  PROCESSING
  COMPLETED
  FAILED
  NOT_FOUND
}

model RecognitionResult {
  id          String   @id @default(uuid())
  uploadId    String   @unique
  upload      Upload   @relation(fields: [uploadId], references: [id], onDelete: Cascade)
  trackTitle  String?
  artist      String?
  album       String?
  genre       String?
  bpm         Int?
  mood        String?
  releaseYear Int?
  duration    Int?
  spotifyUrl  String?  @db.Text
  youtubeUrl  String?  @db.Text
  coverUrl    String?  @db.Text
  confidence  Float?
  rawResponse Json?
  createdAt   DateTime @default(now())
  feedback    Feedback?

  @@map("recognition_results")
}

model Feedback {
  id                  String            @id @default(uuid())
  recognitionResultId String            @unique
  recognitionResult   RecognitionResult @relation(fields: [recognitionResultId], references: [id], onDelete: Cascade)
  isCorrect           Boolean
  correctTrackTitle   String?
  correctArtist       String?
  comment             String?           @db.Text
  createdAt           DateTime          @default(now())

  @@map("feedback")
}