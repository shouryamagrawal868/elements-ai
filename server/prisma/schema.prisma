generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  name      String?
  photoUrl  String?  @db.Text
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  uploads   Upload[]

  @@map("users")
}

model Upload {
  id                String             @id @default(uuid())
  userId            String
  fileName          String
  fileSize          Int
  fileType          String
  status            UploadStatus       @default(UPLOADED)
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
  publicUrl         String?            @db.Text
  storagePath       String             @db.Text
  recognitionResult RecognitionResult?
  user              User               @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("uploads")
}

model RecognitionResult {
  id             String             @id @default(uuid())
  uploadId       String             @unique
  trackTitle     String?
  artist         String?
  album          String?
  genre          String?
  bpm            Int?
  mood           String?
  releaseYear    Int?
  duration       Int?
  spotifyUrl     String?            @db.Text
  youtubeUrl     String?            @db.Text
  coverUrl       String?            @db.Text
  confidence     Float?
  rawResponse    Json?
  createdAt      DateTime           @default(now())
  engine         RecognitionEngine?
  engineVersion  String?
  processingTime Int?
  updatedAt      DateTime           @updatedAt
  feedback       Feedback?
  mlTrainingData MLTrainingData?
  upload         Upload             @relation(fields: [uploadId], references: [id], onDelete: Cascade)

  @@index([trackTitle])
  @@index([artist])
  @@index([confidence])
  @@map("recognition_results")
}

model Feedback {
  id                  String            @id @default(uuid())
  recognitionResultId String            @unique
  isCorrect           Boolean
  correctTrackTitle   String?
  correctArtist       String?
  comment             String?           @db.Text
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  recognitionResult   RecognitionResult @relation(fields: [recognitionResultId], references: [id], onDelete: Cascade)

  @@map("feedback")
}

model MLTrainingData {
  id                  String            @id @default(uuid())
  recognitionResultId String            @unique
  predictedTrack      String?
  predictedArtist     String?
  confidence          Float?
  correctTrack        String?
  correctArtist       String?
  verified            Boolean           @default(false)
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt
  recognitionResult   RecognitionResult @relation(fields: [recognitionResultId], references: [id], onDelete: Cascade)

  @@index([verified])
  @@map("ml_training_data")
}

enum UploadStatus {
  UPLOADED
  EXTRACTING_AUDIO
  RECOGNIZING
  COMPLETED
  FAILED
}

enum RecognitionEngine {
  ACOUSTID
  AUDD
  MUSICBRAINZ
  CUSTOM_AI
}
